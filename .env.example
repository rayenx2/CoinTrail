# CoinTrail — Environment Variables
# Copy this file to .env and adjust values as needed.
# All defaults below already work out of the box with `docker compose up`.

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=expense_tracker_db
DB_USER=postgres
DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Cache (Redis)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Auth / JWT
# Generate your own secret for production:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# ---------------------------------------------------------------------------
# Mail (optional — not required to run the app)
# The mail health indicator is disabled by default (management.health.mail.enabled=false)
# because no real SMTP credentials are needed for local development or demos.
# ---------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@cointrail.local
MAIL_PASSWORD=unused

# ---------------------------------------------------------------------------
# CORS
# Comma-separated list of origins allowed to call the API. Must match the
# frontend's host port exactly (see docker-compose.yml).
# ---------------------------------------------------------------------------
APP_CORS_ALLOWED_ORIGINS=http://localhost:5062

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8060
